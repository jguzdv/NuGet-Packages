{
  "compileOnSave": true,
  "compilerOptions": {
    "outDir": "wwwroot",
    "module": "ES6",
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES6",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "moduleResolution": "Node"
  },
  "exclude": [ "node_modules" ]
}
