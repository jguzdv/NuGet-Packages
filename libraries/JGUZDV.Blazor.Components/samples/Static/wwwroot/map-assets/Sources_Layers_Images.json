{
  "sources": {
    "ArisSource": {
      "type": "geojson",
      "data": "map-assets/ArisTest.json"
    },
    "TestSource": {
      "type": "geojson",
      "data": ""
    }
  },
  "layers": [
    {
      "id": "TestSiteFillLayer",
      "type": "fill",
      "source": "ArisSource",
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "fill-color": "rgb(0,0,255)",
        "fill-opacity": 0.4
      },
      "filter": [ "==", "type", "Site" ]

    },
    {
      "id": "TestSiteLineLayer",
      "type": "line",
      "source": "ArisSource",
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgb(0,0, 0)",
        "line-opacity": 1,
        "line-width": 3
      },
      "filter": [ "==", "type", "Site" ]
    },
    {
      "id": "TestBuildingPointLayer",
      "type": "symbol",
      "source": "ArisSource",
      "layout": {
        "visibility": "visible",
        "icon-image": "catpicture",
        "icon-size": 0.1
      },
      "maxzoom": 24,
      "minzoom": 13,
      "filter": [ "==", "type", "Building2" ]

    },
    {
      "id": "TestBuildingPointLayerZwei",
      "type": "symbol",
      "source": "TestSource",
      "layout": {
        "visibility": "visible",
        "icon-image": "bluemarker",
        "icon-size": 1.5
      },
      "maxzoom": 24,
      "minzoom": 13,
      "filter": [ "==", "type", "Building2" ]

    }
  ],
  "images": [
    {
      "id": "catpicture",
      "imgUrl": "https://upload.wikimedia.org/wikipedia/commons/7/7c/201408_cat.png"
    },
    {
      "id": "bluemarker",
      "imgUrl": "/map-assets/bluemarker.png"
    }
  ]
}