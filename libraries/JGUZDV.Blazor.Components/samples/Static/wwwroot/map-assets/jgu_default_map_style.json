    {
      "id": "BuildingOutlineLayer",
      "type": "line",
      "source": "ArisSource",
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgb(193,0, 42)",
        "line-opacity": 1,
        "line-width": 2
      },
      "filter": [
        "all",
        [ "==", "type", "BuildingOutline" ],
        [ "==", "isNotable", true ]
      ]
    },
    {
      "id": "BuildingLayer",
      "type": "fill",
      "source": "ArisSource",
      "layout": {
        "visibility": "visible"
      },
